# Neon Postgres (shared with findy-core)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# TikTok scraping (Apify)
APIFY_TOKEN=

# Video analysis (Google Gemini Files API — required for TikTok video)
GEMINI_API_KEY=

# Text LLM via OpenRouter (resolveLocations, canonicalizePlaces)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-nemo

# Geocoding fallback + Places Text Search verification (same key as frontend)
GOOGLE_PLACES_API_KEY=

# Web reinforcement pipeline
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Upstash Workflow / QStash (required at deploy time)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Optional: OpenAI fallback for video analysis (local ingest-from-file --provider openai)
OPENAI_API_KEY=
